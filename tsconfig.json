{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "outDir": "out",
        "rootDir": "src",
        "lib": [
            "es2020",
            "dom"
        ],
        "types": [
            "node",
            "mocha"
        ],
        "sourceMap": true,
        "resolveJsonModule": true,
        "typeRoots": [
            "declarations",
            "node_modules/@types",
            "node_modules/@autojs",
            "node_modules/@sm003/autojs6-dts/declarations"
        ],
        "allowJs": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "out",
        ".vscode-test",
        "assets",
        "test-*.js",
        "example-*.js"
    ]
}